	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Auto-generate client code if not set",
					"if (!pm.collectionVariables.get('client_code')) {",
					"    pm.collectionVariables.set('client_code', 'LS000123');",
					"}"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Auto-extract token from login response",
					"if (pm.response.json() && pm.response.json().Token) {",
					"    pm.collectionVariables.set('auth_token', pm.response.json().Token);",
					"    console.log('Auth token saved to collection variables');",
					"}",
					"",
					"// Auto-extract client code from token",
					"if (pm.response.json() && pm.response.json().Token) {",
					"    const token = pm.response.json().Token;",
					"    const payload = JSON.parse(atob(token.split('.')[1]));",
					"    if (payload.ClientCode || payload.clientcode || payload.sub) {",
					"        const clientCode = payload.ClientCode || payload.clientcode || payload.sub;",
					"        pm.collectionVariables.set('client_code', clientCode);",
					"        console.log('Client code extracted from token:', clientCode);",
					"    }",
					"}"
				]
			}
		}
	],
